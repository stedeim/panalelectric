rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users collection ─────────────────────────────────────────────
    // Each user can ONLY read and write their own document.
    // They CANNOT read other users' data.
    match /users/{userId} {
      // Authenticated user can read their own document
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Authenticated user can write their own document
      // But they cannot change their own uid (not possible via SDK anyway)
      // Tier/status can only be written via Firebase Admin SDK (server-side webhook)
      // For client-side writes, consider locking tier/status to prevent tampering
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Public product data (if you add a products collection) ───────
    // Unauthenticated read allowed for public product listings
    // No writes from client
    // match /products/{productId} {
    //   allow read: if true;
    //   allow write: if false;
    // }

    // ── Deny all other paths by default ─────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
